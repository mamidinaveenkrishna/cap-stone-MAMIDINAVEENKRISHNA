{
  "name": "Vendor_Invoice_Management_System",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/resilience": "^4.7.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-invoice-management": "cds watch --open vendor.invoice.invoicemanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy Vendor_Invoice_Management_System --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-vendor-management": "cds watch --open vendor.invoice.vendormanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-invoiceapproval": "cds watch --open vendor.invoice.invoiceapproval/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-invoiceviewer": "cds watch --open vendor.invoice.invoiceviewer/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "alice": {
            "password": "alice",
            "roles": [
              "Admin",
              "Approver",
              "VendorManager",
              "Viewer"
            ]
          },
          "bob": {
            "password": "bob",
            "roles": [
              "Approver",
              "Viewer"
            ]
          },
          "vendor": {
            "password": "vendor",
            "roles": [
              "VendorManager",
              "Viewer"
            ]
          },
          "viewer": {
            "password": "viewer",
            "roles": [
              "Viewer"
            ]
          }
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "html5-repo": true,
      "destinations": true,
      "workzone": true,
      "API_BUSINESS_PARTNER": {
        "kind": "odata-v2",
        "model": "srv/external/API_BUSINESS_PARTNER",
        "credentials": {
          "destination": "S4HANA"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/invoice-management",
    "app/invoice-management",
    "app/vendor-management",
    "app/vendor-management",
    "app/invoiceapproval",
    "app/vendor-management",
    "app/invoiceviewer",
    "app/invoiceapproval"
  ]
}
